-- Třetí výzkumná otázka: Která kategorie potravin zdražuje nejpomaleji (je u ní nejnižší percentuální meziroční nárůst)? 
-- metoda řešení: pomocí okenní funkce LAG jsem vypočítala meziroční procentuální změnu ceny pro každou kategorii potravin ve všech dostupných letech
-- poté jsem z těchto hodnot vypočítala průměrný meziroční nárůst pro každou kategorii a výsledky seřadila od nejnižšího, výsledkem je tedy jediná hodnota
ODPOVĚĎ: Nejpomalejší nárůst (respektive průměrný pokles) vykazuje Cukr krystalový s hodnotou -1,92 %.
WITH price_changes AS (
    SELECT 
        food_category,
        year,
        average_price,
        LAG(average_price) OVER (PARTITION BY food_category ORDER BY year) as prev_price
    FROM data_academy_content.t_gloria_gupta_project_sql_primary_final
    GROUP BY food_category, year, average_price
)
SELECT 
    food_category,
    ROUND(AVG((average_price - prev_price) / prev_price * 100), 2) as avg_yearly_growth_pct
FROM price_changes
WHERE prev_price IS NOT NULL
GROUP BY food_category
ORDER BY avg_yearly_growth_pct ASC
LIMIT 1;
