-- První výzkumná otázka: Rostou v průběhu let mzdy ve všech odvětvích, nebo v některých klesají?
-- dle mého názoru lze pojmout dvěma způsoby - buď sledujeme meziroční změny nebo celkovou změnu mezi prvním a posledním rokem, připravila jsem obě varianty

-- Pojetí 1 - změna první x poslední rok
-- metoda řešení - vytvořila jsem novou tabulku, kde jsou jednotlivá odvětví, mzda v prvním a posledním roce měření a jejich rozdíl
-- poslední sloupec Rostou / Klesají je pro přehlenost
-- ODPOVĚĎ: ve všech odvětvích mzdy rostou
WITH payroll_extremes AS (
    SELECT 
        industry,
        year,
        average_wage,
        FIRST_VALUE(average_wage) OVER (PARTITION BY industry ORDER BY year) as first_wage,
        LAST_VALUE(average_wage) OVER (PARTITION BY industry ORDER BY year ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING) as last_wage  
        -- poslední dva řádky jsem řešila se znalejším partnerem a AI, nevěděla jsem, jak problém řešit jen s příkazy z kurzu
    FROM data_academy_content.t_gloria_gupta_project_sql_primary_final
)
SELECT 
    industry,
    first_wage,
    last_wage,
    (last_wage - first_wage) as total_diff,
    CASE WHEN last_wage > first_wage THEN 'Rostou' ELSE 'Klesají' END as trend
FROM payroll_extremes
GROUP BY industry, first_wage, last_wage;

-- Pojetí 2 - meziroční změny
-- metoda řešení - tato tabulka sleduje i meziroční změny
-- ODPOVĚĎ: téměř ve všech odvětvích mzdy také klesaly
WITH annual_comparison AS (
    SELECT 
        industry,
        year,
        average_wage,
        LAG(average_wage) OVER (PARTITION BY industry ORDER BY year) as prev_wage
    FROM data_academy_content.t_gloria_gupta_project_sql_primary_final
)
SELECT 
    industry,
    MIN(average_wage - prev_wage) as min_change,
    CASE 
        WHEN MIN(average_wage - prev_wage) < 0 THEN 'Mzda v některých letech klesala'
        ELSE 'Mzda každý rok rostla (nebo stagnovala)'
    END as status
FROM annual_comparison
GROUP BY industry;
