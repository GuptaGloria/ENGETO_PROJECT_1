-- Pátá výzkumná otázka: Má výška HDP vliv na změny ve mzdách a cenách potravin? Neboli, pokud HDP vzroste výrazněji v jednom roce, projeví se to na cenách potravin či mzdách ve stejném nebo následujícím roce výraznějším růstem?
-- metoda řešení: propojila jsem data o HDP (sekundární tabulka) s průměrnými mzdami a cenami potravin (primární tabulka). Vypočítala jsem meziroční procentuální změny všech ukazatelů
-- pro zjištění vlivu s časovým posunem jsem porovnala růst HDP v předchozím roce ($N-1$) s růstem mezd a cen v roce aktuálním ($N$)
-- do skriptu jsem přidala sloupeček, která vyhodnocuje "Možný vliv", pokud se obě veličiny pohybovaly stejným směrem.
-- ODPOVĚĎ: mzdy mají tendenci kopírovat růstový trend HDP (často s mírným zpožděním), ceny potravin vykazují vyšší kolísavost, která pravděpodobně závisí na jiných faktorech
-- ekonomický růst (HDP) má prokazatelný vliv na růst mezd se zpožděním jednoho roku
-- u cen potravin je tento vliv méně čitelný, což naznačuje, že potraviny reagují na širší spektrum vnějších vlivů než jen na výkon domácí ekonomiky

WITH economy_data AS (
    SELECT 
        year,
        GDP as gdp,
        LAG(GDP) OVER (ORDER BY year) as prev_gdp
    FROM data_academy_content.t_gloria_gupta_project_sql_secondary_final
    WHERE country = 'Czech Republic'
),
payroll_food_data AS (
    SELECT 
        year,
        AVG(average_price) as avg_price,
        AVG(average_wage) as avg_wage
    FROM data_academy_content.t_gloria_gupta_project_sql_primary_final
    GROUP BY year
),
growth_calculations AS (
    SELECT 
        p.year,
        ROUND(((e.gdp - e.prev_gdp) / e.prev_gdp * 100)::numeric, 2) as gdp_growth,
        ROUND(((p.avg_price - LAG(p.avg_price) OVER (ORDER BY p.year)) / LAG(p.avg_price) OVER (ORDER BY p.year) * 100)::numeric, 2) as food_growth,
        ROUND(((p.avg_wage - LAG(p.avg_wage) OVER (ORDER BY p.year)) / LAG(p.avg_wage) OVER (ORDER BY p.year) * 100)::numeric, 2) as wage_growth
    FROM payroll_food_data p
    JOIN economy_data e ON p.year = e.year
),
final_comparison AS (
    SELECT 
        year,
        gdp_growth,
        food_growth,
        wage_growth,
        LAG(gdp_growth) OVER (ORDER BY year) as gdp_growth_prev_year
    FROM growth_calculations
)
SELECT 
    *,
    CASE 
        WHEN gdp_growth_prev_year > 0 AND wage_growth > 0 THEN 'Možný vliv (oba rostou)'
        WHEN gdp_growth_prev_year < 0 AND wage_growth < 0 THEN 'Možný vliv (oba klesají)'
        WHEN gdp_growth_prev_year IS NULL THEN 'N/A (chybí data)'
        ELSE 'Bez přímého vlivu'
    END as influence_on_wages
FROM final_comparison;
