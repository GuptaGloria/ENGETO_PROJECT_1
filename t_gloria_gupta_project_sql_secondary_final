WITH food_prices_yearly AS (
    -- 1. Agregace cen potravin na průměr za rok
    SELECT 
        YEAR(date_from) AS year,
        AVG(value) AS avg_food_price
    FROM czechia_price
    GROUP BY YEAR(date_from)
),
gdp_yearly AS (
    -- 2. Získání HDP pro Českou republiku z tabulky economies
    SELECT 
        year,
        gdp
    FROM economies
    WHERE country = 'Czech Republic'
)
-- 3. Finální spojení a výpočet meziročních změn v procentech
SELECT 
    f.year,
    f.avg_food_price,
    g.gdp,
    -- Výpočet meziročního nárůstu cen v %
    ROUND((f.avg_food_price - LAG(f.avg_food_price) OVER (ORDER BY f.year)) / LAG(f.avg_food_price) OVER (ORDER BY f.year) * 100, 2) AS food_price_growth_pct,
    -- Výpočet meziročního nárůstu HDP v %
    ROUND((g.gdp - LAG(g.gdp) OVER (ORDER BY g.year)) / LAG(g.gdp) OVER (ORDER BY g.year) * 100, 2) AS gdp_growth_pct
FROM food_prices_yearly f
JOIN gdp_yearly g ON f.year = g.year
ORDER BY f.year;
